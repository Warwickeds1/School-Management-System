@model SchoolManagementSystem.Models.Report
@using System.Text.Json

@{
    ViewData["Title"] = "Report Snapshot Audit";
}

<div class="card shadow border-0 rounded-3 overflow-hidden" style="max-width: 800px; margin: 0 auto;">
    <!-- Gray Secondary Header -->
    <div class="bg-secondary text-white p-4 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="fw-bold m-0">Operational Report Snapshot</h3>
            <p class="text-white-50 m-0 small">Static system audit log compiled on @Model.GeneratedDate.ToString("g")</p>
        </div>
        <span class="badge bg-light text-dark px-3 py-2 fw-bold text-uppercase">@Model.Category</span>
    </div>

    <div class="card-body p-4">
        <!-- Scope Section -->
        <div class="row mb-4 bg-light p-3 rounded-3 border">
            <div class="col-md-6 border-end">
                <span class="text-muted d-block small">Report Label</span>
                <strong class="text-dark fs-5">@Model.Name</strong>qq
            </div>
            <div class="col-md-3 border-end">
                <span class="text-muted d-block small">Generated By</span>
                <strong class="text-secondary">@Model.GeneratedBy</strong>
            </div>
            <div class="col-md-3">
                <span class="text-muted d-block small">Scope Bounds</span>
                @if (!string.IsNullOrEmpty(Model.QueryParametersJson))
                {
                    using (JsonDocument doc = JsonDocument.Parse(Model.QueryParametersJson))
                    {
                        var root = doc.RootElement;
                        <strong class="text-secondary small">
                            @root.GetProperty("StartDate").GetString() to @root.GetProperty("EndDate").GetString()
                        </strong>
                    }
                }
                else
                {
                    <strong class="text-secondary">All-Time History</strong>
                }
            </div>
        </div>

        <!-- Render Snapshotted Data on the Fly depending on Category -->
        @if (!string.IsNullOrEmpty(Model.DataSnapshotJson))
        {
            using (JsonDocument doc = JsonDocument.Parse(Model.DataSnapshotJson))
            {
                var root = doc.RootElement;

                if (Model.Category == "Financial")
                {
                    <!-- Financial Analytics Widgets -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 bg-success-subtle text-success border border-success-subtle rounded-3 text-center">
                                <span class="d-block small text-uppercase fw-semibold">Total Revenue Invoiced</span>
                                <span class="fs-4 fw-bold">Rs. @root.GetProperty("TotalInvoiced").GetDecimal().ToString("N2")</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-success text-white rounded-3 text-center">
                                <span class="d-block small text-white-50 text-uppercase fw-semibold">Total Revenue Collected</span>
                                <span class="fs-4 fw-bold">Rs. @root.GetProperty("TotalCollected").GetDecimal().ToString("N2")</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-danger-subtle text-danger border border-danger-subtle rounded-3 text-center">
                                <span class="d-block small text-uppercase fw-semibold">Outstanding Deficits</span>
                                <span class="fs-4 fw-bold">Rs. @root.GetProperty("TotalOutstanding").GetDecimal().ToString("N2")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Line Item Sub-table -->
                    <h5 class="fw-bold mb-3 text-secondary border-bottom pb-2">Archived Invoice Records</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped border rounded">
                            <thead>
                                <tr class="bg-light">
                                    <th>Student Account</th>
                                    <th>Liability Charged</th>
                                    <th>Due Date</th>
                                    <th class="text-end">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in root.GetProperty("LineItems").EnumerateArray())
                                {
                                    <tr>
                                        <td>@item.GetProperty("StudentName").GetString()</td>
                                        <td class="fw-semibold">Rs. @item.GetProperty("Amount").GetDecimal().ToString("N2")</td>
                                        <td>@item.GetProperty("DueDate").GetString()</td>
                                        <td class="text-end">
                                            @if (item.GetProperty("IsPaid").GetBoolean())
                                            {
                                                <span class="badge bg-success">Settled</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Outstanding</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (Model.Category == "Attendance")
                {
                    <!-- Attendance Analytics Widgets -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="p-3 bg-primary-subtle text-primary border rounded-3 text-center">
                                <span class="d-block small text-uppercase fw-semibold">Total Records Logged</span>
                                <span class="fs-4 fw-bold">@root.GetProperty("TotalLogs").GetInt32()</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-success-subtle text-success border rounded-3 text-center">
                                <span class="d-block small text-uppercase fw-semibold">Presents Registered</span>
                                <span class="fs-4 fw-bold">@root.GetProperty("PresentCount").GetInt32()</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-danger-subtle text-danger border rounded-3 text-center">
                                <span class="d-block small text-uppercase fw-semibold">Absences Logged</span>
                                <span class="fs-4 fw-bold">@root.GetProperty("AbsentCount").GetInt32()</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 bg-success text-white rounded-3 text-center">
                                <span class="d-block small text-white-50 text-uppercase fw-semibold">Attendance Rate</span>
                                <span class="fs-4 fw-bold">@root.GetProperty("AttendanceRate").GetDouble()%</span>
                            </div>
                        </div>
                    </div>

                    <!-- Attendance Details Table -->
                    <h5 class="fw-bold mb-3 text-secondary border-bottom pb-2">Archived Daily Attendance Roster</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped border rounded">
                            <thead>
                                <tr class="bg-light">
                                    <th>Student Account</th>
                                    <th>Date Logged</th>
                                    <th class="text-end">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in root.GetProperty("LineItems").EnumerateArray())
                                {
                                    <tr>
                                        <td>@item.GetProperty("StudentName").GetString()</td>
                                        <td>@item.GetProperty("Date").GetString()</td>
                                        <td class="text-end">
                                            <span class="badge @(item.GetProperty("Status").GetString() == "Present" ? "bg-success" : "bg-danger")">
                                                @item.GetProperty("Status").GetString()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else // Enrollment Metrics View
                {
                    <div class="row g-4 mt-1">
                        <div class="col-md-4">
                            <div class="card border text-center p-3">
                                <i class="bi bi-people-fill text-primary fs-2 mb-2"></i>
                                <span class="text-muted small">Total Students Enrolled</span>
                                <h3 class="fw-bold">@root.GetProperty("TotalStudents").GetInt32()</h3>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border text-center p-3">
                                <i class="bi bi-person-workspace text-info fs-2 mb-2"></i>
                                <span class="text-muted small">Active Academic Classrooms</span>
                                <h3 class="fw-bold">@root.GetProperty("TotalClasses").GetInt32()</h3>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border text-center p-3">
                                <i class="bi bi-mortarboard-fill text-success fs-2 mb-2"></i>
                                <span class="text-muted small">Registered Faculty Advisors</span>
                                <h3 class="fw-bold">@root.GetProperty("TotalTeachers").GetInt32()</h3>
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="alert alert-warning">
                <strong>⚠️ Warning:</strong> Data snapshot payload is corrupted or empty. Unable to parse query totals.
            </div>
        }

        <!-- Administrative remarks display block -->
        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div class="mt-4 p-3 bg-light rounded-3 border">
                <span class="text-muted small fw-semibold text-uppercase d-block mb-1">Administrative Annotation</span>
                <p class="mb-0 text-dark small">@Model.Remarks</p>
            </div>
        }

        <!-- Footer actions alignment panel -->
        <div class="d-flex gap-2 justify-content-end bg-light m-n4 mt-4 p-3 rounded-bottom border-top">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to Archive</a>
        </div>
    </div>
</div>