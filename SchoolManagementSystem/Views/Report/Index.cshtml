<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
@model IEnumerable<SchoolManagementSystem.Models.Report>

@{
    ViewData["Title"] = "Reports & Analytics Archive";
}

<div class="w-100 px-2">
    <!-- Action Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Reports & Analytics</h2>
            <p class="text-muted small mb-0">Compile, view, and audit school-wide operational snapshots</p>
        </div>
        <a asp-action="Create" class="btn btn-success d-flex align-items-center gap-2 px-4 shadow-sm">
            <i class="bi bi-file-earmark-bar-graph-fill"></i> Compile New Report
        </a>
    </div>

    <!-- Data Table Card -->
    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary border-bottom">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-uppercase small">Report Name</th>
                            <th class="py-3 fw-semibold text-uppercase small">Category</th>
                            <th class="py-3 fw-semibold text-uppercase small">Date Compiled</th>
                            <th class="py-3 fw-semibold text-uppercase small">Generated By</th>
                            <th class="py-3 fw-semibold text-uppercase small">Remarks</th>
                            <th class="pe-4 py-3 text-end fw-semibold text-uppercase small">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-file-earmark-text fs-1 d-block mb-2 text-secondary"></i>
                                    No generated reports in archive. Click "Compile New Report" to start.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-bold text-dark">
                                        @item.Name
                                    </td>
                                    <td class="py-3">
                                        <span class="badge @(item.Category == "Financial" ? "bg-success-subtle text-success" : item.Category == "Attendance" ? "bg-warning-subtle text-warning text-dark" : "bg-info-subtle text-info") px-2 py-1.5 rounded fw-medium">
                                            @item.Category
                                        </span>
                                    </td>
                                    <td class="py-3 text-secondary small">
                                        @item.GeneratedDate.ToString("g")
                                    </td>
                                    <td class="py-3 text-secondary small">
                                        @item.GeneratedBy
                                    </td>
                                    <td class="py-3 text-muted small text-truncate" style="max-width: 200px;">
                                        @(string.IsNullOrEmpty(item.Remarks) ? "—" : item.Remarks)
                                    </td>
                                    <td class="pe-4 py-3 text-end">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-2.5" title="View Audit Details">
                                                <i class="bi bi-info-circle"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-2.5" title="Purge Record">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>