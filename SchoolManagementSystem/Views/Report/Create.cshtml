@model SchoolManagementSystem.Models.Report

@{
    ViewData["Title"] = "Compile Operational Report";
}

<div class="card shadow border-0 rounded-3 overflow-hidden" style="max-width: 650px; margin: 0 auto;">
    <!-- Green Success Header -->
    <div class="bg-success text-white p-4">
        <h3 class="fw-bold m-0">Compile Operational Report</h3>
        <p class="text-white-50 m-0 small">Select parameters to generate static analytical data snapshots</p>
    </div>

    <div class="card-body p-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Report Name -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary">Custom Report Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Q1 Class Performance Summary" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!-- Report Category selection -->
            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-semibold text-secondary">Target Metrics Category</label>
                <select asp-for="Category" class="form-select">
                    <option value="Financial">Financial (Ledgers, Collections, Outstanding Balance)</option>
                    <option value="Attendance">Attendance (Class Logging, Percentages, Absences)</option>
                    <option value="Enrollment">Enrollment (Operational Ratios, Class Density)</option>
                </select>
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <!-- Filter Criteria Date Bounds -->
            <div class="row mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold text-secondary">Query Start Date</label>
                    <input type="date" name="startDate" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold text-secondary">Query End Date</label>
                    <input type="date" name="endDate" class="form-control" />
                </div>
            </div>

            <!-- Remarks -->
            <div class="mb-4">
                <label asp-for="Remarks" class="form-label fw-semibold text-secondary">Administrative Remarks / Purpose</label>
                <textarea asp-for="Remarks" class="form-control" rows="2" placeholder="Describe the scope or targets of this compiled document..."></textarea>
                <span asp-validation-for="Remarks" class="text-danger small"></span>
            </div>

            <!-- Action footer alignment wrapper -->
            <div class="d-flex gap-2 justify-content-end bg-light m-n4 mt-4 p-3 rounded-bottom border-top">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-success px-4 text-white">Compile and Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}