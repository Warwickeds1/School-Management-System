<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
@model IEnumerable<SchoolManagementSystem.Models.Class>

@{
    ViewData["Title"] = "School Classes";
}

<div class="w-100 px-2">
    <!-- Top Action Row -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Class Manager</h2>
            <p class="text-muted small mb-0">Create classes, track assigned sections, and assign faculty advisors</p>
        </div>
        <a asp-action="Create" class="btn btn-success d-flex align-items-center gap-2 px-4 shadow-sm text-white fw-semibold">
            <i class="bi bi-plus-circle-fill"></i> Add New Class
        </a>
    </div>

    <!-- Main Data Frame Card -->
    <div class="card shadow border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary border-bottom">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-uppercase small">Class Name</th>
                            <th class="py-3 fw-semibold text-uppercase small">Section / Room</th>
                            <th class="py-3 fw-semibold text-uppercase small">Assigned Teacher</th>
                            <th class="py-3 fw-semibold text-uppercase small">Class Room No.</th>
                            <th class="pe-4 py-3 text-end fw-semibold text-uppercase small">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-journal-bookmark fs-2 d-block mb-2 text-secondary"></i>
                                    No classes configured. Click "Add New Class" to set one up.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <!-- 1. Class Name -->
                                    <td class="ps-4 py-3 fw-bold text-dark">
                                        @item.ClassName
                                    </td>

                                    <!-- 2. Section/Room -->
                                    <td class="py-3 text-dark fw-medium">
                                        @item.Section
                                    </td>

                                    <!-- 3. Advisor Teacher Name -->
                                    <td class="py-3 text-primary fw-semibold">
                                        @(item.Teacher?.Name ?? "Unassigned")
                                    </td>
                                    
                                    <!-- 3. Class Room No.-->
                                    <td class="py-3 text-primary fw-semibold">
                                        @(item.RoomNumber ?? "Unassigned")
                                    </td>

                                    <!-- 4. Cohesive Outlined Action Icons -->
                                    <td class="pe-4 py-3 text-end">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning px-2.5" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-2.5" title="Details">
                                                <i class="bi bi-info-circle"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-2.5" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>