@model SchoolManagementSystem.Models.Class

@{
    ViewData["Title"] = "Add New Class Track";
}

<div class="card shadow border-0 rounded-3">
    <div class="bg-success p-4 text-white text-center rounded-top">
        <h4 class="fw-bold m-0">Create Academic Class</h4>
        <small class="text-white-50">Establish a new classroom division roster</small>
    </div>

    <div class="card-body p-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label asp-for="TeacherId" class="control-label">Assign Teacher</label>

                <!-- MUST target TeacherId directly -->
                <select asp-for="TeacherId" class="form-control" asp-items="ViewBag.TeacherId">
                    <option value="">-- Select Teacher --</option>
                </select>

                <span asp-validation-for="TeacherId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ClassName" class="form-label fw-semibold text-secondary">Class Name / Grade</label>
                <input asp-for="ClassName" class="form-control" placeholder="e.g., Grade 10" />
                <span asp-validation-for="ClassName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Section" class="form-label fw-semibold text-secondary">Assigned Section</label>
                <input asp-for="Section" class="form-control" placeholder="e.g., Section C" />
                <span asp-validation-for="Section" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="RoomNumber" class="form-label fw-semibold text-secondary">Classroom Room No.</label>
                <input asp-for="RoomNumber" class="form-control" placeholder="e.g., 77" />
                <span asp-validation-for="RoomNumber" class="text-danger small"></span>
            </div>

           

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                <button type="submit" class="btn btn-success px-4">Save Class</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}