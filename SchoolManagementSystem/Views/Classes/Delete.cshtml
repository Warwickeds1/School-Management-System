@model SchoolManagementSystem.Models.Class

@{
    ViewData["Title"] = "Remove Class Track";
}

<div class="card shadow border-0 rounded-3 border-top border-danger border-5">
    <div class="p-4 text-center">
        <div class="text-danger mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
            </svg>
        </div>
        <h4 class="fw-bold text-danger m-0">Decommission Class Track?</h4>
        <p class="text-muted small mt-1">Are you sure you want to permanently delete this record? This action cannot be reversed.</p>
    </div>

    <div class="card-body bg-light p-4 rounded-bottom">
        <div class="d-flex flex-column gap-2 mb-4 fs-6 bg-white p-3 rounded shadow-sm">
            <div class="d-flex">
                <span class="text-secondary fw-semibold" style="width: 150px;">Class Title:</span>
                <span class="text-dark fw-bold">@Model.ClassName</span>
            </div>
            <div class="d-flex">
                <span class="text-secondary fw-semibold" style="width: 150px;">Section allocation:</span>
                <span class="text-dark">@Model.Section</span>
            </div>
            <div class="d-flex">
                <span class="text-secondary fw-semibold" style="width: 150px;">Physical Room:</span>
                <span class="text-muted">Room @Model.RoomNumber</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 justify-content-center">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Keep Record</a>
                <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
            </div>
        </form>
    </div>
</div>