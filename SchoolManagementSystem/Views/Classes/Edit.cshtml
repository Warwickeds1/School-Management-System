@model SchoolManagementSystem.Models.Class

@{
    ViewData["Title"] = "Modify Class Parameters";
}

<div class="card shadow border-0 rounded-3">
    <div class="bg-warning p-4 text-dark text-center rounded-top">
        <h4 class="fw-bold m-0 text-dark">Update Class Workspace</h4>
        <small class="text-muted">Modify allocation configurations for this track</small>
    </div>

    <div class="card-body p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="TeacherId" class="control-label">Assign Teacher</label>

                <!-- MUST target TeacherId directly -->
                <select asp-for="TeacherId" class="form-control" asp-items="ViewBag.TeacherId">
                    <option value="">-- Select Teacher --</option>
                </select>

                <span asp-validation-for="TeacherId" class="text-danger"></span>
            </div>

            <!-- For EDIT view only: Ensure you have a hidden input for the Class Id -->
            <input type="hidden" asp-for="Id" />


            <div class="mb-3">
                <label asp-for="ClassName" class="form-label fw-semibold text-secondary">Class Name / Grade</label>
                <input asp-for="ClassName" class="form-control" />
                <span asp-validation-for="ClassName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Section" class="form-label fw-semibold text-secondary">Assigned Section</label>
                <input asp-for="Section" class="form-control" />
                <span asp-validation-for="Section" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="RoomNumber" class="form-label fw-semibold text-secondary">Classroom Room No.</label>
                <input asp-for="RoomNumber" class="form-control" />
                <span asp-validation-for="RoomNumber" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Back</a>
                <button type="submit" class="btn btn-warning px-4 text-darkfw-semibold">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}