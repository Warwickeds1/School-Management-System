@model SchoolManagementSystem.Models.Student

@{
    ViewData["Title"] = "De-register Student Record";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="alert alert-danger d-flex align-items-center mb-3 shadow-sm" role="alert">
            <div>
                <strong class="text-danger">⚠️ Warning:</strong> Are you absolutely sure you want to permanently delete this student record? This action cannot be undone.
            </div>
        </div>

        <div class="card shadow border-0 rounded-3 overflow-hidden">
            <div class="p-4 bg-white">
                <h4 class="fw-bold text-danger mb-3">Confirm De-registration</h4>
                <hr />
                <dl class="row mb-0">
                    <dt class="col-sm-4 fw-semibold text-muted mb-2">Full Name</dt>
                    <dd class="col-sm-8 fw-bold text-dark mb-2">@Model.Name</dd>

                    <dt class="col-sm-4 fw-semibold text-muted mb-2">Age Bracket</dt>
                    <dd class="col-sm-8 text-dark mb-2">@Model.Age Years</dd>

                    <dt class="col-sm-4 fw-semibold text-muted mb-2">Current Class Link</dt>
                    <dd class="col-sm-8 text-dark mb-2">
                        @if (Model.Class != null)
                        {
                            <span>@Model.Class.ClassName (Section @Model.Class.Section)</span>
                        }
                        else
                        {
                            <span class="text-muted italic">None</span>
                        }
                    </dd>
                </dl>
            </div>

            <div class="card-footer bg-light d-flex justify-content-end gap-2 p-3 border-top-0">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-light border btn-sm px-3">Cancel</a>
                    <button type="submit" class="btn btn-danger btn-sm px-4">Confirm Permanent Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>