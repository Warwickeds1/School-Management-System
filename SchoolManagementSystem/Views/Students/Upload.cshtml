@{
    ViewData["Title"] = "Bulk Import Students";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Bulk Upload Students via CSV</h4>
                </div>
                <div class="card-body">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.ErrorMessage
                        </div>
                    }

                    <p class="text-muted small">
                        Ensure your CSV file contains the following columns in order:
                        <strong>Name, Age, Gender, ClassId</strong> (Do not include an Id column).
                    </p>

                    <!-- CRITICAL attribute: enctype="multipart/form-data" allows binary file streaming -->
                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="file" class="form-label">Select CSV File</label>
                            <input type="file" name="file" id="file" class="form-control" accept=".csv" required />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-success">Upload and Process</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>