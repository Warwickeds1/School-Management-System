@model SchoolManagementSystem.Models.Attendance

@{
    ViewData["Title"] = "Attendance Details";
}

<div class="card shadow border-0 rounded-3 overflow-hidden">
    <!-- Gray Header Block -->
    <div class="bg-primary text-white p-4">
        <h3 class="fw-bold m-0 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle-fill"></i> Attendance Details
        </h3>
    </div>

    <div class="card-body p-4">
        <!-- 1. Full Name -->
        <div class="row mb-3">
            <div class="col-sm-5 text-muted fw-semibold">Student Name</div>
            <div class="col-sm-7 fw-bold text-dark">@(Model.Student?.Name ?? "Unknown Student")</div>
        </div>

        <!-- 2. Date -->
        <div class="row mb-3">
            <div class="col-sm-5 text-muted fw-semibold">Attendance Date</div>
            <div class="col-sm-7 text-dark fw-medium">@Model.Date.ToString("MMMM dd, yyyy")</div>
        </div>

        <!-- 3. Status -->
        <div class="row mb-3">
            <div class="col-sm-5 text-muted fw-semibold">Status Status</div>
            <div class="col-sm-7">
                @if (Model.Status == "Present")
                {
                    <span class="badge bg-success-subtle text-success px-3 py-1.5 rounded-pill fw-bold">Present</span>
                }
                else if (Model.Status == "Absent")
                {
                    <span class="badge bg-danger-subtle text-danger px-3 py-1.5 rounded-pill fw-bold">Absent</span>
                }
                else if (Model.Status == "Late")
                {
                    <span class="badge bg-warning-subtle text-warning px-3 py-1.5 rounded-pill fw-bold">Late</span>
                }
                else
                {
                    <span class="badge bg-secondary-subtle text-secondary px-3 py-1.5 rounded-pill fw-bold">@Model.Status</span>
                }
            </div>
        </div>

        <!-- 4. Remarks -->
        <div class="row mb-4">
            <div class="col-sm-5 text-muted fw-semibold">Teacher Remarks</div>
            <div class="col-sm-7 text-dark italic">@(string.IsNullOrEmpty(Model.Remarks) ? "No remarks submitted" : Model.Remarks)</div>
        </div>

        <!-- Action Buttons Footer -->
        <div class="d-flex gap-2 justify-content-end bg-light m-n4 mt-4 p-3 rounded-bottom border-top">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">Edit Record</a>
        </div>
    </div>
</div>