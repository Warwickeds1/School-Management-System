<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/font/bootstrap-icons.min.css">
@model IEnumerable<SchoolManagementSystem.Models.User>

@{
    ViewData["Title"] = "System Accounts";
}

<div class="w-100 px-2">
    <!-- Top Action Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">System Users</h2>
            <p class="text-muted small mb-0">Configure authentication credentials, portal security, and global roles</p>
        </div>
        <a asp-action="Create" class="btn btn-success d-flex align-items-center gap-2 px-4 shadow-sm text-white fw-semibold">
            <i class="bi bi-person-plus-fill"></i> Create New User
        </a>
    </div>

    <!-- Main Data Frame Card -->
    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary border-bottom">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-uppercase small">Username</th>
                            <th class="py-3 fw-semibold text-uppercase small">Security Code / Password</th>
                            <th class="py-3 fw-semibold text-uppercase small">System Permission Role</th>
                            <th class="pe-4 py-3 text-end fw-semibold text-uppercase small">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-shield-lock fs-2 d-block mb-2 text-secondary"></i>
                                    No user accounts configured. Click "Create New User" to configure security profiles.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <!-- 1. Username Link -->
                                    <td class="ps-4 py-3 fw-bold text-dark">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-person-circle text-secondary"></i>
                                            <span>@item.Username</span>
                                        </div>
                                    </td>

                                    <!-- 2. Obfuscated or Plain Password Representation -->
                                    <td class="py-3 text-secondary font-monospace small">
                                        <code>@item.Password</code>
                                    </td>

                                    <!-- 3. Multi-color Role Authorization Badge -->
                                    <td class="py-3">
                                        @if (item.Role == "Admin")
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-3 py-1.5 rounded fw-bold text-uppercase">
                                                <i class="bi bi-shield-fill-check me-1"></i> Admin
                                            </span>
                                        }
                                        else if (item.Role == "Teacher")
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-1.5 rounded fw-bold text-uppercase">
                                                <i class="bi bi-person-workspace me-1"></i> Teacher
                                            </span>
                                        }
                                        else if (item.Role == "Student")
                                        {
                                            <span class="badge bg-info-subtle text-dark px-3 py-1.5 rounded fw-bold text-uppercase">
                                                <i class="bi bi-mortarboard me-1"></i> Student
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary px-3 py-1.5 rounded fw-bold text-uppercase">
                                                @item.Role
                                            </span>
                                        }
                                    </td>

                                    <!-- 4. Cohesive Functional Action Panels -->
                                    <td class="pe-4 py-3 text-end">
                                        <div class="d-inline-flex gap-1">
                                            <!-- Edit Button -->
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Details Button -->
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Details">
                                                <i class="bi bi-info-circle"></i>
                                            </a>

                                            <!-- Permissions Button (New) -->
                                            <a asp-action="ManagePermissions" asp-route-Role="@item.Role" class="btn btn-sm btn-outline-secondary" title="Permissions">
                                                <i class="bi bi-key-fill"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>