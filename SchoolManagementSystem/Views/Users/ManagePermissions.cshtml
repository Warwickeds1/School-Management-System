@model List<SchoolManagementSystem.Models.RolePermission>

<div class="card shadow border-0 rounded-3">
    <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            Managing Permission For &mdash;
            <span class="text-warning">@ViewData["TargetRole"]</span>
        </h5>
        <span class="badge bg-secondary fw-semibold">Matrix Access Panel</span>
    </div>

    <div class="card-body p-0">
        <form asp-action="UpdatePermissions" method="post">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Module / Feature</th>
                        <th class="text-center" style="width: 15%;">View</th>
                        <th class="text-center" style="width: 15%;">Add</th>
                        <th class="text-center" style="width: 15%;">Update</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td class="fw-semibold ps-4 text-secondary">
                                + @Model[i].Module:
                                <input type="hidden" asp-for="@Model[i].Id" />
                                <input type="hidden" asp-for="@Model[i].Role" />
                                <input type="hidden" asp-for="@Model[i].Module" />
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" asp-for="@Model[i].CanView">
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" asp-for="@Model[i].CanAdd">
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" asp-for="@Model[i].CanUpdate">
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="p-3 bg-light border-top text-end">
                <button type="submit" class="btn btn-primary px-4 fw-semibold shadow-sm">Save Changes</button>
            </div>
        </form>
    </div>
</div>