@inject SchoolManagementSystem.Services.IPermissionService Permission
@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolManagementSystem</title>

    <!-- 1. Centralized Global Stylesheets (No need to repeat these in index views!) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolManagementSystem.styles.css" asp-append-version="true" />

    <style>
        /* Centralized Layout Structure matching image_293bac.png */
        .workspace-wrapper {
            max-width: 1400px;
            width: 100%;
        }

        /* Modern Sidebar Navigation Upgrades */
        .sidebar-nav {
            background: #1e293b !important; /* Premium Dark Slate */
            min-height: 100vh;
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #94a3b8 !important; /* Soft muted text by default */
            text-decoration: none !important;
            font-weight: 500;
            border-left: 4px solid transparent;
            padding: 10px 15px;
            transition: all 0.22s ease-in-out;
            border-radius: 0 8px 8px 0;
            margin-right: 12px;
        }

            /* Dynamic Hover Effect */
            .sidebar-link:hover {
                color: #ffffff !important;
                background: rgba(255, 255, 255, 0.06);
                border-left-color: #3b82f6;
                transform: translateX(6px);
            }

        .sidebar-divider {
            border-top: 1px solid rgba(255, 255, 255, 0.12) !important;
        }

        /* Elegant Table & UI Elements Global Standards */
        .card.shadow {
            border-radius: 12px !important;
            border: none !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04) !important;
        }

        /* Clean action outline buttons global look */
        .btn-outline-warning {
            border-color: #ffc107 !important;
            color: #ffc107 !important;
        }

            .btn-outline-warning:hover {
                background-color: #ffc107 !important;
                color: #fff !important;
            }

        .btn-outline-primary {
            border-color: #0d6efd !important;
            color: #0d6efd !important;
        }

            .btn-outline-primary:hover {
                background-color: #0d6efd !important;
                color: #fff !important;
            }

        .btn-outline-danger {
            border-color: #dc3545 !important;
            color: #dc3545 !important;
        }

            .btn-outline-danger:hover {
                background-color: #dc3545 !important;
                color: #fff !important;
            }
    </style>
</head>
<body>

    <div class="d-flex min-vh-100 alignment-wrapper">

        @if (User?.Identity?.IsAuthenticated == true)
        {
            <nav class="sidebar-nav px-3 pt-4 flex-shrink-0" style="width: 250px;">
                <a class="navbar-brand fs-5 fw-bold d-block mb-4 text-white text-break text-center" asp-area="" asp-controller="Home" asp-action="Index">
                    School Management <span class="d-block text-primary">System</span>
                </a>

                <div class="my-3 sidebar-divider" style="margin-left: -1rem; margin-right: -1rem;"></div>

                <ul class="nav flex-column mb-auto">
                    @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Students", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Students" asp-action="Index">
                                <i class="bi bi-people"></i> Students
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Teachers", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Teachers" asp-action="Index">
                                <i class="bi bi-person-badge"></i> Teachers
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Classes", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Classes" asp-action="Index">
                                <i class="bi bi-door-open"></i> Classes
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Attendance", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Attendance" asp-action="Index">
                                <i class="bi bi-calendar-check"></i> Attendance
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Fees", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Fees" asp-action="Index">
                                <i class="bi bi-cash-stack"></i> Fees
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Users", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Users" asp-action="Index">
                                <i class="bi bi-person-gear"></i> Users
                            </a>
                        </li>
                    }

                    @if (Permission.HasAccess(User, "Report", "View"))
                    {
                        <li class="nav-item mb-2">
                            <a class="nav-link sidebar-link" asp-controller="Report" asp-action="Index">
                                <i class="bi bi-file-earmark-bar-graph"></i> Reports
                            </a>
                        </li>
                    }

                    <li class="nav-item mt-4">
                        <span class="nav-link text-muted small px-3">Hello, @User.Identity.Name! (@User.FindFirst(ClaimTypes.Role)?.Value)</span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                            <button type="submit" class="nav-link btn btn-link sidebar-link text-danger" style="border: none; background: none; width: 100%;">
                                <i class="bi bi-box-arrow-left text-danger"></i> <span class="text-danger">Logout</span>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        }

        <div class="flex-grow-1 pe-5 ps-3 d-flex flex-column justify-content-between bg-light" style="overflow-x: hidden;">

            <div class="workspace-wrapper ms-0 mt-2">
                <main role="main" class="pt-4 pb-3">
                    @RenderBody()
                </main>
            </div>

            <footer class="border-top footer text-muted py-3 mt-auto w-100">
                <div class="workspace-wrapper mx-auto">
                    &copy; 2026 - SchoolManagementSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>